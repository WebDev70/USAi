# USAi Chat — example environment configuration.
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit real secrets; `.env` stays out of version control.

# ── Core (required to chat) ────────────────────────────────────────────────
API_KEY=YOUR_API_KEY_HERE
BASE_URL=https://your-openai-compatible-endpoint/
DEFAULT_MODEL=claude_3_haiku
DEFAULT_SYSTEM_PROMPT=

# ── Optional: Context7 documentation provider ──────────────────────────────
CONTEXT7_API_KEY=
CONTEXT7_BASE_URL=https://context7.com
CONTEXT7_PATH=/api/v2/libs/search
CONTEXT7_METHOD=GET

# ── Optional: Obsidian "second brain" long-term memory ─────────────────────
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/Obsidian Vault
OBSIDIAN_MEMORY_SUBDIR=USAi

# ── Optional: Obsidian-MCP bridge (#16 Ph2) ───────────────────────────────
# Set OBSIDIAN_MCP_PATH to the absolute path of the obsidian-mcp script
# (e.g. the output of: npm root -g)/obsidian-mcp/index.js).
# OBSIDIAN_NODE_PATH can be left as 'node' or set to an absolute path (needed
# when Node is managed via nvm/asdf and not on the server's PATH).
OBSIDIAN_MCP_PATH=
OBSIDIAN_NODE_PATH=node

# ── Optional: Auto model router tier overrides (#19) ──────────────────────
# When set, these model ids are forwarded to the browser via /config and used
# by the client-side TIER_MAP instead of the hardcoded verified defaults.
# Leave blank to use the defaults: claude_4_8_opus / claude_4_6_sonnet / claude_4_5_haiku
TIER_HIGH_MODEL=
TIER_MEDIUM_MODEL=
TIER_LOW_MODEL=

# ── Optional: Network binding ───────────────────────────────────────────────
HOST=
PORT=
