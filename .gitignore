.env
Archive/

# Local Python virtual environment
.venv/

# Continue extension — MCP server configs may contain API keys (e.g. Context7)
.continue/mcpServers/

# Runtime/local state written by the server (not source)
chat_history.json
.chat_sessions/
.chunk_cache/

# macOS cruft
.DS_Store

# Dev-only test-coverage artifacts (coverage.py). The .coveragerc config IS
# tracked; its output files are not. Coverage tooling never ships in the app.
.coverage
.coverage.*
htmlcov/
coverage.xml

# Guard against vault files being written to a literal relative path inside the
# repo (e.g. when an Obsidian filesystem-write fallback uses the wrong base path).
# Vault notes belong in the real Obsidian Vault, never tracked here.
Users/